<!-- vim: set ft=jinja sts=2 sw=2: -->
{% set page_title = "Jan Hermann" %}
{% set canonical = "https://hrmnn.net" %}
{% set meta_description = "Jan Hermann — computational chemist and physicist integrating deep learning into quantum chemistry. Tools, publications, talks, and notes." %}
{% include "templates/_head.html" %}

{% macro talk_block(talks, class) %}
  <table class="{{ class }} small">
    {% for year, items in talks|groupby("year")|sort(reverse=True) %}
      {% for item in items %}
        <tr>
          <td>{% if loop.first %}{{ year }}{% endif %}</td>
          <td class="{% if not loop.first %}continued{% endif %}">
            {% if item.title %}
              “{% if item.url %}<a href="{{ item.url }}">{{ item.title }}</a>{% else %}{{ item.title }}{% endif %}”
            {%- endif %}
            {%- if item.event %}
              {%- if item.title %}&nbsp;&middot; {% endif %}
              {%- if item.event_url %}<a href="{{ item.event_url }}">{{ item.event }}</a>{% else %}{{ item.event }}{% endif %}
            {%- endif %}
            {%- if item.where %}
              {%- if item.title or item.event %} {% endif %}({{ item.where }})
            {%- endif %}
            {%- if item.note %} <em>[{{ item.note }}]</em>{% endif %}
            {%- if item.pdf %}&nbsp;<a href="{{ item.pdf }}">{% include "assets/file-pdf-solid.svg" %}</a>{% endif %}
            {%- if item.video %}&nbsp;<a href="{{ item.video }}">{% include "assets/video-solid.svg" %}</a>{% endif %}
          </td>
        </tr>
      {% endfor %}
    {% endfor %}
  </table>
{% endmacro %}

{# The section's publications in the site's own format (title · authors · ref ·
   PDF · Scholar count), each row carrying its global citation number. `keys` is
   pre-ordered by that number in render.py. #}
{% macro ref_list(keys) %}
  <table class="pub">
    {% for key in keys %}
      {% set item = refs_by_id[key] %}
      {% if item %}
        {% set title, authors, ref = item|reftomd %}
        <tr>
          <td class="cnum">{{ cite_num[key] }}</td>
          <td class="article">
            {{ title }}&nbsp;&middot; {{ authors }}&nbsp;&middot; {{ ref}}
            {%- if item.pdf_url -%}
              &nbsp;<a href="{{ item.pdf_url }}" class="pdf">{% include "assets/file-pdf-solid.svg" %}</a>{%- if item.pdf_notice %}<span class="notice-star">*</span>{% endif %}
              {%- if item.pdf_notice %}<p class="notice">*{{ item.pdf_notice }}{% endif %}
            {%- endif %}
          </td>
          <td>{% if item.cited_by %}{{ item.cited_by }}{% endif %}</td>
        </tr>
      {% endif %}
    {% endfor %}
  </table>
{% endmacro %}

{# A section's tool list — injected, kept out of the prose and the numbering.
   Rendered as on main: name · role · stars inline, description on its own line.
   Program papers are not shown here — they appear in the publications. A hub
   lists its one anchor tool; the theme section lists every unhubbed tool. #}
{% macro software_list(items) %}
  {% if items %}
    <ul class="tools">
      {% for item in items %}
        <li><strong><a href="{{ item.url or 'https://github.com/' ~ item.github }}">{{ item.name }}</a></strong>&nbsp;&middot;
          {{ item.role }}{% if item.stars %}&nbsp;&middot; <em>{{ item.stars }} {% include "assets/github-star.svg" %}</em>{% endif %}
          {% if item.description %}<br>{{ item.description }}{% endif %}
      {% endfor %}
    </ul>
  {% endif %}
{% endmacro %}

{# A homepage section parsed from data/hubs.md (render_hub_sections). Only the
   heading and prose come from the markdown; the rest is injected. Just after the
   heading comes the tool list — a hub's one anchor tool, or the theme section's
   list of every unhubbed tool. Then the prose (with superscript citations), the
   numbered publications, and collapsed talks. #}
{% macro section_block(sec) %}
  {% set talks = theme_talks if sec.theme else hub_talks[sec.id] %}
  <section id="{{ sec.id }}" class="hub">
    <h3>{{ sec.name }}</h3>
    {{ software_list(sec.software) }}
    <div class="miniarticle">{{ sec.html }}</div>
    {{ ref_list(sec.refs) }}
    {% if talks %}
      <details class="hub-extra">
        <summary>Talks ({{ talks|length }})</summary>
        {{ talk_block(talks, "talks small") }}
      </details>
    {% endif %}
  </section>
{% endmacro %}

{% macro dl_block(items, defs) %}
  <dl>
    {% for group, items in items.items() %}
      <dt>{{ group }}</dt>
      <dd>
      {% for item in items %}
        {% if not loop.first %}&middot;{% endif %}
        <a href="{{ defs[item][1] }}{{ defs[item][0] }}" rel="me">{{ item }}</a>
      {% endfor %}
    {% endfor %}
  </dl>
{% endmacro %}

<nav aria-label="Sections">
  <ul>
    <li><a href="#Works">Works</a> ({% for sec in sections if not sec.theme %}{% if not loop.first %} &middot; {% endif %}<a href="#{{ sec.id }}">{{ sec.nav }}</a>{% endfor %})
    <li><a href="#CV">CV</a> (as <a href="cv.pdf">{% include "assets/file-pdf-solid.svg" %}</a>)
    <li><a href="/notes/">Notes</a>
  </ul>
</nav>

<main>

  <div class="h-card">

  <h1 class="p-name"><a rel="me" class="u-url" href="https://hrmnn.net"><span id="firstname">Jan</span> Hermann</a></h1>
  {# Verifies ownership of the Bridgy Fed (fed.brid.gy) bridged account. #}
  <a rel="me" href="https://web.brid.gy/hrmnn.net" hidden></a>
  {# Mastodon verifies a remote account's profile links against its `url` field,
     which Bridgy Fed serves in this redirect form (not the actor id above), so
     this rel=me is what earns the green "verified link" badge. The scheme must
     match exactly: Bridgy Fed now serves the url over https (it used to be http). #}
  <a rel="me" href="https://web.brid.gy/r/https://hrmnn.net/" hidden></a>
  {# Transparent u-featured so the bridged Mastodon profile uses a blank header
     instead of falling back to the avatar (u-photo) for its banner. #}
  <img class="u-featured" src="header-blank.png" alt="" hidden>

  <section>
    {# Opt out of the Bridgy Fed bridge (fed.brid.gy): the literal `#nobridge`
       in the h-card note tells fed.brid.gy not to bridge this site into the
       fediverse (federating directly instead). `hidden` keeps it out of the
       rendered bio while leaving it in the parsed p-note that fed.brid.gy reads
       — the same reason the rel=me links above use `hidden`. #}
    <p class="p-note">{{ bio }}<span hidden> #nobridge</span>
    
    <p id="profile-pic"><img class="u-photo" src="profile-pic-web.jpeg" alt="Jan Hermann" width="160" height="160">
    
    {{ dl_block(links, contact) }}
  </section>

  </div>

  <h2 id="Works">Works</h2>
  {% if tools_lead %}<div id="tools-lead">{{ tools_lead }}</div>{% endif %}

  {% for sec in sections %}
    {{ section_block(sec) }}
  {% endfor %}

  <section id="CV" aria-label="CV">
    <h2>Employment</h2>
    <table class="cvblock">
      {% for item in employment %}
        <tr class="heading">
          <td></td>
          <td><strong>{{ item.institution }}</strong>{% if item.location %}, {{ item.location }}{% endif %}</td>
        </tr>
        {% for position in item.positions %}
          <tr>
            <td>{{ position.date|dateformat }}</td>
            <td>{{ position.role }}&nbsp;&middot; {{ position.dept }}</td>
          </tr>
        {% endfor %}
      {% endfor %}
    </table>

    <h2 id="Education">Education</h2>
      <table class="cvblock">
      {% for item in education %}
        <tr class="heading">
          <td></td>
          <td><strong>{{ item.university }}</strong>{% if item.location %}, {{ item.location }}{% endif %}</td>
        </tr>
        {% for degree in item.degrees %}
          <tr>
            <td>{{ degree.date|dateformat }}</td>
            <td><strong>{{ degree.degree }}</strong> in <strong>{{ degree.field }}</strong>{% if degree.note %}&nbsp;&middot; <em>{{ degree.note }}</em>{% endif %}</td>
          </tr>
        {% endfor %}
      {% endfor %}
    </table>

    <h2>Secondary appointments</h2>
    <table class="cvblock">
      {% for item in secondary %}
        <tr>
          <td>{{ item.date|dateformat }}</td>
          <td>
            {{ item.role }}&nbsp;&middot; {{ item.where }}
            {% if item.subtitle %}<br/>{{ item.subtitle }}{% endif %}
          </td>
        </tr>
      {% endfor %}
    </table>

    <h2>Awards</h2>
    <table class="cvblock">
      {% for item in awards %}
        <tr>
          <td>{{ item.date|dateformat }}</td>
          <td>
            <strong>{{ item.title }}</strong>
            {%- if item.institution %}&nbsp;&middot; {{ item.institution}}{% endif %}
            {% if item.note %} <em>[{{ item.note }}]</em>{% endif %}
          </td>
      {% endfor %}
    </table>

    <!-- <h2>Funding</h2> -->
    <!-- <table class="cvblock"> -->
    <!--   {% for item in funding %} -->
    <!--     <tr> -->
    <!--       <td>{{ item.date|dateformat }}</td> -->
    <!--       <td> -->
    <!--         {{ item.label }}&#38;nbsp;&#38;middot; “{{ item.title }}”&#38;nbsp;&#38;middot; <strong>{{ item.sum }}</strong> -->
    <!--         {% if item.subtitle %}<br/>{{ item.subtitle }}{% endif %} -->
    <!--       </td> -->
    <!--     </tr> -->
    <!--   {% endfor %} -->
    <!-- </table> -->

    <h2>Professional activities</h2>
    <ul>
      {% for item in activity %}<li>{{ item }}{% endfor %}
    </ul>
  </section>
</main>

{% include "templates/_footer.html" %}

<script type="application/json" id="custom-data">
{{ custom_data|tojson }}
</script>