<!-- vim: set ft=jinja sts=2 sw=2: -->
{% set page_title = "Jan Hermann" %}
{% set canonical = "https://jan.hermann.name" %}
{% include "templates/_head.html" %}

{% macro talk_block(talks, class) %}
  <table class="{{ class }} small">
    {% for year, items in talks|groupby("year")|sort(reverse=True) %}
      {% for item in items %}
        <tr>
          <td>{% if loop.first %}{{ year }}{% endif %}</td>
          <td class="{% if not loop.first %}continued{% endif %}">
            {% if item.title %}
              “{% if item.url %}<a href="{{ item.url }}">{{ item.title }}</a>{% else %}{{ item.title }}{% endif %}”
            {%- endif %}
            {%- if item.event %}
              {%- if item.title %}&nbsp;&middot; {% endif %}
              {%- if item.event_url %}<a href="{{ item.event_url }}">{{ item.event }}</a>{% else %}{{ item.event }}{% endif %}
            {%- endif %}
            {%- if item.where %}
              {%- if item.title or item.event %} {% endif %}({{ item.where }})
            {%- endif %}
            {%- if item.note %} <em>[{{ item.note }}]</em>{% endif %}
            {%- if item.pdf %}&nbsp;<a href="{{ item.pdf }}">{% include "assets/file-pdf-solid.svg" %}</a>{% endif %}
            {%- if item.video %}&nbsp;<a href="{{ item.video }}">{% include "assets/video-solid.svg" %}</a>{% endif %}
          </td>
        </tr>
      {% endfor %}
    {% endfor %}
  </table>
{% endmacro %}

{# A tool-hub: name + repo, then the pandoc-rendered miniarticle (narrative prose
   with superscript citations + its numbered reference list), then collapsed talks.
   The miniarticle HTML is built in render.py (render_hub_sections). #}
{% macro hub_block(tool) %}
  {% set repo = software_by_github[tool.github] %}
  <section id="{{ tool.name }}" class="hub">
    <h2>{{ tool.name }}
      <a class="hub-repo small" href="https://github.com/{{ tool.github }}">{{ tool.github }}</a>{% if repo and repo.stars %}&nbsp;<em class="small">{{ repo.stars }} {% include "assets/github-star.svg" %}</em>{% endif %}
    </h2>
    <div class="miniarticle">{{ hub_html[tool.name] }}</div>
    {% if hub_talks[tool.name] %}
      <details class="hub-extra">
        <summary>Talks ({{ hub_talks[tool.name]|length }})</summary>
        {{ talk_block(hub_talks[tool.name], "talks small") }}
      </details>
    {% endif %}
  </section>
{% endmacro %}

{% macro dl_block(items, defs) %}
  <dl>
    {% for group, items in items.items() %}
      <dt>{{ group }}</dt>
      <dd>
      {% for item in items %}
        {% if not loop.first %}&middot;{% endif %}
        <a href="{{ defs[item][1] }}{{ defs[item][0] }}" rel="me">{{ item }}</a>
      {% endfor %}
    {% endfor %}
  </dl>
{% endmacro %}

<nav aria-label="Sections">
  <ul>
    {% for tool in tools %}<li><a href="#{{ tool.name }}">{{ tool.name }}</a>{% endfor %}
    <li><a href="#{{ fourth_theme.id }}">{{ fourth_theme.name }}</a>
    <li><a href="#CV">CV</a> (as <a href="cv.pdf">{% include "assets/file-pdf-solid.svg" %}</a>)
    <li><a href="/notes/">Notes</a>
  </ul>
</nav>

<main>

  <div class="h-card">

  <h1 class="p-name"><a rel="me" class="u-url" href="https://jan.hermann.name"><span id="firstname">Jan</span> Hermann</a></h1>
  {# Verifies ownership of the Bridgy Fed (fed.brid.gy) bridged account. #}
  <a rel="me" href="https://web.brid.gy/jan.hermann.name" hidden></a>
  {# Mastodon verifies a remote account's profile links against its `url` field,
     which Bridgy Fed serves in this redirect form (not the actor id above), so
     this rel=me is what earns the green "verified link" badge. #}
  <a rel="me" href="http://web.brid.gy/r/https://jan.hermann.name/" hidden></a>
  {# Transparent u-featured so the bridged Mastodon profile uses a blank header
     instead of falling back to the avatar (u-photo) for its banner. #}
  <img class="u-featured" src="header-blank.png" alt="" hidden>

  <section>  
    <p class="p-note">{{ bio }}
    
    <p id="profile-pic"><img class="u-photo" src="profile-pic.jpeg" alt="Jan Hermann" height="160">
    
    {{ dl_block(links, contact) }}
  </section>

  </div>

  <p id="tools-lead">My work clusters around a handful of tools, each tying together its
    method papers, applications, and talks. Threaded physics-first to learning-first,
    they share one aim: making electronic structure more accurate, by adding the missing
    physics by hand or by learning it.

  {% for tool in tools %}
    {{ hub_block(tool) }}
  {% endfor %}

  <section id="{{ fourth_theme.id }}" class="hub">
    <h2>{{ fourth_theme.name }}</h2>
    <div class="miniarticle">{{ theme_html }}</div>
    <ul class="theme-tools">
      {% for item in other_tools %}
        <li><strong><a href="{{ item.url or 'https://github.com/' ~ item.github }}">{{ item.name }}</a></strong>&nbsp;&middot; <em>built</em>{% if item.description %}&nbsp;&middot; {{ item.description }}{% endif %}{% if item.stars %}&nbsp;&middot; {{ item.stars }} {% include "assets/github-star.svg" %}{% endif %}
      {% endfor %}
      {% for item in contributes %}
        {% set p = refs_by_id[item.paper] if item.paper %}
        <li><strong><a href="{{ item.url or 'https://github.com/' ~ item.github }}">{{ item.name }}</a></strong>&nbsp;&middot; <em>contributor</em>{% if p %}&nbsp;&middot;
          <a href="{% if p.pdf_url %}{{ p.pdf_url }}{% elif p.DOI %}https://doi.org/{{ p.DOI }}{% else %}{{ p.URL }}{% endif %}">program paper</a>{% endif %}
      {% endfor %}
    </ul>
    {% if theme_talks %}
      <details class="hub-extra">
        <summary>Talks ({{ theme_talks|length }})</summary>
        {{ talk_block(theme_talks, "talks small") }}
      </details>
    {% endif %}
  </section>

  <section id="CV" aria-label="CV">
    <h2>Employment</h2>
    <table class="cvblock">
      {% for item in employment %}
        <tr class="heading">
          <td></td>
          <td><strong>{{ item.institution }}</strong>{% if item.location %}, {{ item.location }}{% endif %}</td>
        </tr>
        {% for position in item.positions %}
          <tr>
            <td>{{ position.date|dateformat }}</td>
            <td>{{ position.role }}&nbsp;&middot; {{ position.dept }}</td>
          </tr>
        {% endfor %}
      {% endfor %}
    </table>

    <h2 id="Education">Education</h2>
      <table class="cvblock">
      {% for item in education %}
        <tr class="heading">
          <td></td>
          <td><strong>{{ item.university }}</strong>{% if item.location %}, {{ item.location }}{% endif %}</td>
        </tr>
        {% for degree in item.degrees %}
          <tr>
            <td>{{ degree.date|dateformat }}</td>
            <td><strong>{{ degree.degree }}</strong> in <strong>{{ degree.field }}</strong>{% if degree.note %}&nbsp;&middot; <em>{{ degree.note }}</em>{% endif %}</td>
          </tr>
        {% endfor %}
      {% endfor %}
    </table>

    <h2>Secondary appointments</h2>
    <table class="cvblock">
      {% for item in secondary %}
        <tr>
          <td>{{ item.date|dateformat }}</td>
          <td>
            {{ item.role }}&nbsp;&middot; {{ item.where }}
            {% if item.subtitle %}<br/>{{ item.subtitle }}{% endif %}
          </td>
        </tr>
      {% endfor %}
    </table>

    <h2>Awards</h2>
    <table class="cvblock">
      {% for item in awards %}
        <tr>
          <td>{{ item.date|dateformat }}</td>
          <td>
            <strong>{{ item.title }}</strong>
            {%- if item.institution %}&nbsp;&middot; {{ item.institution}}{% endif %}
            {% if item.note %} <em>[{{ item.note }}]</em>{% endif %}
          </td>
      {% endfor %}
    </table>

    <!-- <h2>Funding</h2> -->
    <!-- <table class="cvblock"> -->
    <!--   {% for item in funding %} -->
    <!--     <tr> -->
    <!--       <td>{{ item.date|dateformat }}</td> -->
    <!--       <td> -->
    <!--         {{ item.label }}&#38;nbsp;&#38;middot; “{{ item.title }}”&#38;nbsp;&#38;middot; <strong>{{ item.sum }}</strong> -->
    <!--         {% if item.subtitle %}<br/>{{ item.subtitle }}{% endif %} -->
    <!--       </td> -->
    <!--     </tr> -->
    <!--   {% endfor %} -->
    <!-- </table> -->

    <h2>Professional activities</h2>
    <ul>
      {% for item in activity %}<li>{{ item }}{% endfor %}
    </ul>

    <h2>Teaching & mentoring</h2>

    <h3>Professional mentorship</h3>
    <table class="cvblock small">
      {% for item in mentorship %}
        <tr>
          <td>{{ item.date|dateformat }}</td>
          <td>{{ item.who }}</td>
        </tr>
      {% endfor %}
    </table>

    <h3>Lectures for students</h3>
    {{ talk_block(lectures, "talks small") }}

    <h3>Doctoral committees</h3>
    <table class="cvblock small">
      {% for item in defense %}
        <tr>
          <td>{{ item.date|dateformat }}</td>
          <td>{{ item.who }}</td>
        </tr>
      {% endfor %}
    </table>

    <h2>Public outreach</h2>
    <table class="cvblock small">
      {% for item in outreach %}
        <tr>
          <td>{{ item.date|dateformat }}</td>
          <td>{{ item.what }}</td>
        </tr>
      {% endfor %}
    </table>
  </section>
</main>

{% include "templates/_footer.html" %}

<script type="application/json" id="custom-data">
{{ custom_data|tojson }}
</script>